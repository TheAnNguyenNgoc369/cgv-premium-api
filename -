    [ShowingFrom] date NULL,
    [ShowingTo] date NULL,
    [Status] nvarchar(30) NOT NULL DEFAULT N'coming_soon',
    [CreatedAt] datetime2 NOT NULL DEFAULT (GETDATE()),
    [UpdatedAt] datetime2 NOT NULL DEFAULT (GETDATE()),
