CREATE TABLE [PaymentSession] (
    [SessionID] int NOT NULL IDENTITY,
    [PaymentID] int NOT NULL,
    [GatewayName] nvarchar(50) NOT NULL,
    [GatewayOrderNo] nvarchar(200) NULL,
    [QRCodeURL] nvarchar(500) NULL,
    [ExpiresAt] datetime2 NOT NULL,
    [Status] nvarchar(30) NOT NULL DEFAULT N'waiting',
    [CreatedAt] datetime2 NOT NULL DEFAULT (GETDATE()),
    CONSTRAINT [PK_PaymentSession] PRIMARY KEY ([SessionID]),
    CONSTRAINT [CK_PaymentSession_GatewayName] CHECK ([GatewayName] IN ('payos', 'momo')),
    CONSTRAINT [CK_PaymentSession_Status] CHECK ([Status] IN ('waiting', 'processing', 'completed', 'expired', 'cancelled')),
    CONSTRAINT [FK_PaymentSession_Payment] FOREIGN KEY ([PaymentID]) REFERENCES [Payment] ([PaymentID])
);
