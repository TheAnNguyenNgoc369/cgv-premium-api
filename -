CREATE TABLE [UserVoucher] (
    [UserVoucherID] int NOT NULL IDENTITY,
    [UserID] int NOT NULL,
    [VoucherID] int NOT NULL,
    [RedeemedAt] datetime2 NOT NULL,
    [ExpiredAt] datetime2 NOT NULL,
    [Status] nvarchar(20) NOT NULL,
    [UsedAt] datetime2 NULL,
    [BookingID] int NULL,
    CONSTRAINT [PK_UserVoucher] PRIMARY KEY ([UserVoucherID]),
    CONSTRAINT [CK_UserVoucher_Dates] CHECK ([ExpiredAt] >= [RedeemedAt]),
    CONSTRAINT [CK_UserVoucher_Status] CHECK ([Status] IN ('available', 'used', 'expired')),
    CONSTRAINT [FK_UserVoucher_Booking] FOREIGN KEY ([BookingID]) REFERENCES [Booking] ([BookingID]),
    CONSTRAINT [FK_UserVoucher_Users] FOREIGN KEY ([UserID]) REFERENCES [Users] ([UserID]),
    CONSTRAINT [FK_UserVoucher_Voucher] FOREIGN KEY ([VoucherID]) REFERENCES [Voucher] ([VoucherID])
);
GO


CREATE TABLE [Ticket] (
    [TicketID] int NOT NULL IDENTITY,
    [BookingSeatID] int NOT NULL,
    [QRCode] nvarchar(500) NOT NULL,
    [Status] nvarchar(20) NOT NULL DEFAULT N'valid',
    [CheckedInAt] datetime2 NULL,
    [CheckedInByID] int NULL,
    CONSTRAINT [PK_Ticket] PRIMARY KEY ([TicketID]),
    CONSTRAINT [CK_Ticket_Status] CHECK ([Status] IN ('valid', 'used', 'cancelled')),
