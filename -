    CONSTRAINT [FK_WalletTransaction_Refund] FOREIGN KEY ([RefundID]) REFERENCES [Refund] ([RefundID]),
    CONSTRAINT [FK_WalletTransaction_Wallet] FOREIGN KEY ([WalletID]) REFERENCES [Wallet] ([WalletID])
);
